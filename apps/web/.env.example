# =============================================================================
# Cocoa Ranch & Industry — Variables d'environnement (exemple)
# =============================================================================
# Copier ce fichier en .env.local et renseigner les valeurs réelles.
# NE JAMAIS COMMITER .env.local ou tout fichier contenant des secrets.
# =============================================================================

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Cocoa Ranch & Industry"
NEXT_PUBLIC_APP_ENV="development"

# ─── Firebase (client) ───────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="cri-app.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="cri-app"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="cri-app.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="0000000000"
NEXT_PUBLIC_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxxx"
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# Firebase App Check (reCAPTCHA Enterprise key)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# ─── Firebase Admin (server-side uniquement) ─────────────────────────────────
FIREBASE_PROJECT_ID="cri-app"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@cri-app.iam.gserviceaccount.com"
# Clé privée du service account (garder les retours à la ligne en JSON)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Sécurité ────────────────────────────────────────────────────────────────
# Secret pour signer les session cookies (32+ caractères aléatoires)
SESSION_COOKIE_SECRET="generate-a-strong-random-secret-min-32-chars"

# Clé de chiffrement at-rest pour champs sensibles (32 bytes base64)
ENCRYPTION_KEY=""

# ─── Services tiers ──────────────────────────────────────────────────────────
# Brevo (ex-Sendinblue) — email
BREVO_API_KEY=""

# Plausible — analytics RGPD-friendly
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="cri.africa"

# Sentry — monitoring erreurs
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Google Maps API (optionnel, pour enrichir Leaflet)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Feature flags ───────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_TERRAIN="true"
NEXT_PUBLIC_ENABLE_INVESTORS="true"
NEXT_PUBLIC_ENABLE_FIELD_OFFLINE="true"

# ─── Bundle analyzer ─────────────────────────────────────────────────────────
# Définir à "true" pour analyser le bundle : ANALYZE=true npm run build
ANALYZE="false"
